<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SGP - Agendamento Premium</title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script async src="https://unpkg.com/es-module-shims@1.6.3/dist/es-module-shims.js"></script>
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.150.1/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.150.1/examples/jsm/"
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700&display=swap');

        :root {
            --bg-body: #1a1a1a;
            --bg-sidebar: #1f1f1f;
            --bg-card: #262626;
            --bg-input: #303030;
            --primary: #686868;
            --accent: #004ba8;
            --text-main: #ffffff;
            --text-muted: #a1a0a0;
            --border-radius: 8px;
            --font: "Nunito", sans-serif;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            background-color: var(--bg-body); 
            color: var(--text-main); 
            font-family: var(--font); 
            display: flex; 
            height: 100vh; 
            overflow: hidden; 
        }

        /* --- Sidebar Profissionais --- */
        .lg-sidebar-booking {
            width: 320px;
            background-color: var(--bg-sidebar);
            border-right: 1px solid rgba(255,255,255,0.05);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        .lg-sidebar-header {
            padding: 24px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .lg-sidebar-header h2 { font-size: 18px; font-weight: 700; }

        .lg-pro-card {
            padding: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.03);
            cursor: pointer;
            transition: background 0.2s;
        }

        .lg-pro-card:hover { background: rgba(255,255,255,0.02); }
        .lg-pro-card.active { background: rgba(0, 75, 168, 0.1); border-left: 3px solid var(--accent); }

        .lg-pro-info { display: flex; align-items: center; gap: 12px; margin-bottom: 15px; }
        .lg-pro-avatar { width: 44px; height: 44px; border-radius: 50%; object-fit: cover; background: #444; }
        .lg-pro-name { font-weight: 600; font-size: 14px; }

        /* Dias e Horários */
        .lg-week-grid { display: flex; gap: 4px; overflow-x: auto; padding-bottom: 10px; }
        .lg-day-pill {
            flex: 1;
            padding: 8px;
            background: var(--bg-input);
            border-radius: 4px;
            text-align: center;
            font-size: 10px;
            min-width: 45px;
        }
        .lg-day-pill span { display: block; font-weight: 700; color: var(--text-muted); }

        .lg-hours-container { 
            display: none; 
            grid-template-columns: repeat(3, 1fr); 
            gap: 8px; 
            margin-top: 15px; 
            animation: fadeIn 0.3s ease;
        }
        .lg-pro-card.active .lg-hours-container { display: grid; }
        
        .lg-hour-btn {
            padding: 6px;
            background: var(--bg-body);
            border: 1px solid var(--primary);
            color: var(--text-muted);
            border-radius: 4px;
            font-size: 11px;
            cursor: pointer;
            text-align: center;
        }
        .lg-hour-btn:hover, .lg-hour-btn.selected { background: var(--accent); color: white; border-color: var(--accent); }

        /* --- Centro: Visualizador 3D --- */
        .lg-viewport-3d {
            flex-grow: 1;
            position: relative;
            display: flex;
            flex-direction: column;
        }

        #canvas-container { flex-grow: 1; width: 100%; height: 100%; cursor: grab; }

        .lg-hair-pallete {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 15px;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(10px);
            padding: 12px 24px;
            border-radius: 50px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .lg-hair-option {
            width: 40px; height: 40px;
            border-radius: 50%;
            border: 2px solid transparent;
            cursor: pointer;
            background-size: cover;
            transition: 0.2s;
        }
        .lg-hair-option:hover { transform: scale(1.1); }
        .lg-hair-option.active { border-color: var(--accent); }

        /* --- Lateral Direita: Formulário --- */
        .lg-form-panel {
            width: 350px;
            background-color: var(--bg-sidebar);
            padding: 32px;
            border-left: 1px solid rgba(255,255,255,0.05);
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .lg-form-group { display: flex; flex-direction: column; gap: 8px; }
        .lg-label { font-size: 10px; text-transform: uppercase; font-weight: 700; color: var(--primary); letter-spacing: 1px; }
        .lg-input, .lg-select {
            background: var(--bg-input);
            border: 1px solid rgba(255,255,255,0.1);
            color: white;
            padding: 12px;
            border-radius: var(--border-radius);
            font-family: var(--font);
            font-size: 13px;
        }

        .lg-btn-submit {
            margin-top: auto;
            background: var(--accent);
            color: white;
            padding: 16px;
            border-radius: var(--border-radius);
            font-weight: 700;
            text-transform: uppercase;
            border: none;
            cursor: pointer;
            transition: 0.3s;
        }
        .lg-btn-submit:hover { filter: brightness(1.2); }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <aside class="lg-sidebar-booking">
        <div class="lg-sidebar-header">
            <h2>Profissionais</h2>
        </div>
        
        <div class="lg-pro-card active" onclick="selectPro(this, 'Ricardo Silva')">
            <div class="lg-pro-info">
                <img src="https://i.pravatar.cc/150?u=2" alt="Avatar" class="lg-pro-avatar">
                <div class="lg-pro-name">Ricardo Silva</div>
            </div>
            <div class="lg-week-grid">
                <div class="lg-day-pill"><span>SEG</span>12</div>
                <div class="lg-day-pill"><span>TER</span>13</div>
                <div class="lg-day-pill"><span>QUA</span>14</div>
            </div>
            <div class="lg-hours-container">
                </div>
        </div>

        <div class="lg-pro-card" onclick="selectPro(this, 'Ana Beatriz')">
            <div class="lg-pro-info">
                <img src="https://i.pravatar.cc/150?u=1" alt="Avatar" class="lg-pro-avatar">
                <div class="lg-pro-name">Ana Beatriz</div>
            </div>
            <div class="lg-week-grid">
                <div class="lg-day-pill"><span>SEG</span>12</div>
                <div class="lg-day-pill"><span>TER</span>13</div>
            </div>
            <div class="lg-hours-container"></div>
        </div>
    </aside>

    <main class="lg-viewport-3d">
        <div id="canvas-container"></div>
        
        <div class="lg-hair-pallete">
            <div class="lg-hair-option active" style="background-color: #3d2b1f;" onclick="changeHair('hair1.glb', this)" title="Corte Social"></div>
            <div class="lg-hair-option" style="background-color: #1a1a1a;" onclick="changeHair('hair2.glb', this)" title="Degradê Moderno"></div>
            <div class="lg-hair-option" style="background-color: #d4af37;" onclick="changeHair('hair3.glb', this)" title="Pompadour"></div>
        </div>
    </main>

    <section class="lg-form-panel">
        <h2 style="font-size: 18px; margin-bottom: 10px;">Dados do Agendamento</h2>
        
        <div class="lg-form-group">
            <label class="lg-label">Nome Completo</label>
            <input type="text" id="clienteNome" class="lg-input" placeholder="Ex: João Silva">
        </div>

        <div class="lg-form-group">
            <label class="lg-label">Telefone</label>
            <input type="tel" id="clienteTelefone" class="lg-input" placeholder="(11) 99999-9999">
        </div>

        <div class="lg-form-group">
            <label class="lg-label">Data de Nascimento</label>
            <input type="date" id="clienteNascimento" class="lg-input">
        </div>

        <div class="lg-form-group">
            <label class="lg-label">Tipo de Serviço</label>
            <select id="tipoServico" class="lg-select">
                <option value="Corte">Corte Masculino</option>
                <option value="Barba">Barba Tradicional</option>
                <option value="Completo">Corte & Barba</option>
            </select>
        </div>

        <div style="background: rgba(255,255,255,0.03); padding: 15px; border-radius: 8px; font-size: 12px; color: var(--text-muted);">
            <p>Profissional: <b id="displayPro" style="color: white;">Ricardo Silva</b></p>
            <p>Horário: <b id="displayHora" style="color: white;">Não selecionado</b></p>
        </div>

        <button class="lg-btn-submit" onclick="finalizarAgendamento()">Confirmar Agendamento</button>
    </section>

   <script type="module">
    import * as THREE from 'three';
    import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
    import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

    let scene, camera, renderer, model, controls;
    const container = document.getElementById('canvas-container');

    function init3D() {
        scene = new THREE.Scene();
        
        // Ajuste o FOV e a posição da câmera
        camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
        camera.position.set(0, 0, 5); // Afastei um pouco a câmera

        renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(container.clientWidth, container.clientHeight);
        renderer.setPixelRatio(window.devicePixelRatio);
        container.appendChild(renderer.domElement);

        // Luzes mais fortes para garantir visibilidade
        const ambientLight = new THREE.AmbientLight(0xffffff, 1.5);
        scene.add(ambientLight);

        const pointLight = new THREE.PointLight(0xffffff, 2);
        pointLight.position.set(5, 5, 5);
        scene.add(pointLight);

        controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;

        // Carrega o primeiro modelo
        loadModel('hair1.glb');
        animate();
    }

    function loadModel(name) {
        const loader = new GLTFLoader();
        const path = `/glb/${name}`;

        loader.load(path, (gltf) => {
            if (model) scene.remove(model);
            
            model = gltf.scene;

            // --- TRUQUE DE ESCALA E CENTRALIZAÇÃO ---
            const box = new THREE.Box3().setFromObject(model);
            const size = box.getSize(new THREE.Vector3());
            const center = box.getCenter(new THREE.Vector3());

            // Redimensiona o modelo automaticamente para caber na tela
            const maxDim = Math.max(size.x, size.y, size.z);
            const fscale = 2 / maxDim;
            model.scale.set(fscale, fscale, fscale);

            // Reposiciona o centro
            model.position.x = (model.position.x - center.x) * fscale;
            model.position.y = (model.position.y - center.y) * fscale;
            model.position.z = (model.position.z - center.z) * fscale;

            scene.add(model);
            console.log("Modelo carregado com sucesso:", name);
        }, 
        (xhr) => {
            console.log((xhr.loaded / xhr.total * 100) + '% carregado');
        },
        (error) => {
            console.error("Erro crítico ao carregar:", error);
        });
    }

    function animate() {
        requestAnimationFrame(animate);
        if(controls) controls.update();
        renderer.render(scene, camera);
    }

    // EXPOSTO PARA O ONCLICK FUNCIONAR
    window.changeHair = (modelName, element) => {
        document.querySelectorAll('.lg-hair-option').forEach(el => el.classList.remove('active'));
        element.classList.add('active');
        loadModel(modelName);
    };

    window.addEventListener('resize', () => {
        camera.aspect = container.clientWidth / container.clientHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(container.clientWidth, container.clientHeight);
    });

    init3D();
</script>

    <script>
        // --- Lógica de Negócio ---
        let selectedPro = "Ricardo Silva";
        let selectedTime = "";
        let selectedDate = new Date().toISOString().split('T')[0];

        // Gerador de horários (30 min)
        function generateHours() {
            const containers = document.querySelectorAll('.lg-hours-container');
            containers.forEach(container => {
                container.innerHTML = '';
                for (let h = 9; h <= 18; h++) {
                    ['00', '30'].forEach(m => {
                        const time = `${h}:${m}`;
                        const btn = document.createElement('div');
                        btn.className = 'lg-hour-btn';
                        btn.innerText = time;
                        btn.onclick = (e) => {
                            e.stopPropagation();
                            document.querySelectorAll('.lg-hour-btn').forEach(b => b.classList.remove('selected'));
                            btn.classList.add('selected');
                            selectedTime = time;
                            document.getElementById('displayHora').innerText = time;
                        };
                        container.appendChild(btn);
                    });
                }
            });
        }

        window.selectPro = (element, name) => {
            document.querySelectorAll('.lg-pro-card').forEach(c => c.classList.remove('active'));
            element.classList.add('active');
            selectedPro = name;
            document.getElementById('displayPro').innerText = name;
        };

        async function finalizarAgendamento() {
            const payload = {
                nomeCliente: document.getElementById('clienteNome').value,
                telefone: document.getElementById('clienteTelefone').value,
                dataNascimento: document.getElementById('clienteNascimento').value,
                tipoServico: document.getElementById('tipoServico').value,
                profissional: selectedPro,
                horarioAtendimento: selectedTime,
                dataAtendimento: selectedDate
            };

            if (!payload.nomeCliente || !payload.horarioAtendimento) {
                alert("Por favor, preencha o nome e selecione um horário.");
                return;
            }

            console.log("Enviando requisição...", payload);

            try {
                const response = await fetch('/atendimento/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    alert("Agendamento realizado com sucesso!");
                } else {
                    alert("Erro ao realizar agendamento.");
                }
            } catch (error) {
                console.error("Erro de conexão", error);
            }
        }

        window.onload = () => {
            lucide.createIcons();
            generateHours();
        };
    </script>
</body>
</html>