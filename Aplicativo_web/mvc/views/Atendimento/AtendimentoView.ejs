<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalhes do Atendimento</title>
</head>
<body>
    <h1>Detalhes do Atendimento</h1>
    <p><strong>Cliente:</strong> <%= atendimento.nomeCliente %></p>
    <p><strong>Telefone:</strong> <%= atendimento.telefone %></p>
    <p><strong>Data:</strong> <%= atendimento.dataAtendimento %></p>
    <p><strong>Horário:</strong> <%= atendimento.horarioAtendimento %></p>
    <p><strong>Serviço:</strong> <%= atendimento.tipoServico %></p>
    <p><strong>Profissional:</strong> <%= atendimento.profissional %></p>
</body>
</html>